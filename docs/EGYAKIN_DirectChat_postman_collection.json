{
  "info": {
    "name": "EGYAKIN – Direct Chat",
    "description": "Complete API collection for the DirectChat module. All endpoints in testing sequence.\n\nSetup:\n1. Set the {{base_url}} variable to your server (e.g. http://localhost:8000/api/v3)\n2. Run the Login request first — it auto-sets {{token}}, {{user_id}}, {{other_user_id}}\n3. Run requests top-to-bottom in each folder",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",        "value": "http://localhost:8000/api/v3" },
    { "key": "token",           "value": "" },
    { "key": "token_b",         "value": "" },
    { "key": "user_id",         "value": "" },
    { "key": "other_user_id",   "value": "" },
    { "key": "conversation_id", "value": "" },
    { "key": "message_id",      "value": "" },
    { "key": "group_id",        "value": "" }
  ],
  "item": [

    {
      "name": "0 – Auth (get tokens)",
      "item": [
        {
          "name": "Login – User A (main tester)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('user_id', json.data ? json.data.id : '');",
                  "  console.log('Token A saved:', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"userA@example.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Login – User B (second participant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token_b', json.token);",
                  "  pm.collectionVariables.set('other_user_id', json.data ? json.data.id : '');",
                  "  console.log('Token B saved:', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"userB@example.com\",\n  \"password\": \"password\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "1 – User Search",
      "item": [
        {
          "name": "Search users by name",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('value true', () => pm.expect(json.value).to.be.true);",
                  "pm.test('data is array', () => pm.expect(json.data).to.be.an('array'));",
                  "if (json.data && json.data.length > 0) {",
                  "  pm.collectionVariables.set('other_user_id', json.data[0].id);",
                  "  console.log('other_user_id set to', json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/users/search?q=sara",
              "host": ["{{base_url}}"],
              "path": ["chat", "users", "search"],
              "query": [{ "key": "q", "value": "sara" }]
            }
          }
        },
        {
          "name": "Search users – too short (expect 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));",
                  "pm.test('value false', () => pm.expect(pm.response.json().value).to.be.false);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/users/search?q=a",
              "host": ["{{base_url}}"],
              "path": ["chat", "users", "search"],
              "query": [{ "key": "q", "value": "a" }]
            }
          }
        }
      ]
    },

    {
      "name": "2 – Private Chat (send direct)",
      "item": [
        {
          "name": "Send direct text message (auto-creates private chat)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('value true', () => pm.expect(json.value).to.be.true);",
                  "pm.test('has conversation_id', () => pm.expect(json.data.conversation_id).to.be.a('number'));",
                  "pm.collectionVariables.set('conversation_id', json.data.conversation_id);",
                  "pm.collectionVariables.set('message_id', json.data.id);",
                  "console.log('Private conversation_id:', json.data.conversation_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/direct/{{other_user_id}}",
              "host": ["{{base_url}}"],
              "path": ["chat", "direct", "{{other_user_id}}"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"type\": \"text\",\n  \"content\": \"Hello! This is the first message.\"\n}"
            }
          }
        },
        {
          "name": "Send direct again (must reuse existing conversation)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('same conversation_id', () => {",
                  "  pm.expect(json.data.conversation_id).to.equal(Number(pm.collectionVariables.get('conversation_id')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/direct/{{other_user_id}}",
              "host": ["{{base_url}}"],
              "path": ["chat", "direct", "{{other_user_id}}"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"type\": \"text\",\n  \"content\": \"Second message — same conversation.\"\n}"
            }
          }
        },
        {
          "name": "Send direct to self (expect 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/direct/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["chat", "direct", "{{user_id}}"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"type\": \"text\",\n  \"content\": \"Self message\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "3 – Conversation List",
      "item": [
        {
          "name": "Get all conversations (with counts + embedded messages)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('value true', () => pm.expect(json.value).to.be.true);",
                  "pm.test('has counts', () => {",
                  "  pm.expect(json.data.counts).to.have.all.keys('all','private','case_group','social_group');",
                  "});",
                  "pm.test('has data array', () => pm.expect(json.data.data).to.be.an('array'));",
                  "pm.test('has pagination meta', () => pm.expect(json.data.meta).to.exist);",
                  "if (json.data.data.length > 0) {",
                  "  var first = json.data.data[0];",
                  "  pm.test('conversation has messages array', () => pm.expect(first.messages).to.be.an('array'));",
                  "  pm.test('has unread_count', () => pm.expect(first.unread_count).to.be.a('number'));",
                  "  pm.test('has messages_has_more', () => pm.expect(first.messages_has_more).to.be.a('boolean'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations"]
            }
          }
        },
        {
          "name": "Get conversations – filter by private",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations?type=private",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations"],
              "query": [{ "key": "type", "value": "private" }]
            }
          }
        },
        {
          "name": "Get conversations – page 2",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations?page=2",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations"],
              "query": [{ "key": "page", "value": "2" }]
            }
          }
        }
      ]
    },

    {
      "name": "4 – Conversation Detail",
      "item": [
        {
          "name": "Get conversation details",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('value true', () => pm.expect(json.value).to.be.true);",
                  "pm.test('has participants', () => pm.expect(json.data.participants).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations/{{conversation_id}}",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations", "{{conversation_id}}"]
            }
          }
        },
        {
          "name": "Get conversation – non-member (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 or 404', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([403, 404]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations/999999",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations", "999999"]
            }
          }
        }
      ]
    },

    {
      "name": "5 – Messages",
      "item": [
        {
          "name": "Get messages (first page, auto-reads)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('data is array', () => pm.expect(json.data).to.be.an('array'));",
                  "pm.test('has has_more', () => pm.expect(json.has_more).to.be.a('boolean'));",
                  "if (json.data.length > 0) {",
                  "  var oldest = json.data[0].id;",
                  "  pm.collectionVariables.set('message_id', json.data[json.data.length - 1].id);",
                  "  console.log('oldest message id for pagination:', oldest);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations/{{conversation_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations", "{{conversation_id}}", "messages"]
            }
          }
        },
        {
          "name": "Get messages – paginate older (before cursor)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations/{{conversation_id}}/messages?before={{message_id}}",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations", "{{conversation_id}}", "messages"],
              "query": [{ "key": "before", "value": "{{message_id}}" }]
            }
          }
        },
        {
          "name": "Send text message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('value true', () => pm.expect(json.value).to.be.true);",
                  "pm.test('type is text', () => pm.expect(json.data.type).to.equal('text'));",
                  "pm.test('has sender', () => pm.expect(json.data.sender).to.exist);",
                  "pm.collectionVariables.set('message_id', json.data.id);",
                  "console.log('message_id saved:', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations/{{conversation_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations", "{{conversation_id}}", "messages"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"type\": \"text\",\n  \"content\": \"Hello from Postman!\"\n}"
            }
          }
        },
        {
          "name": "Send text message with reply_to",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('has reply_to', () => pm.expect(json.data.reply_to).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations/{{conversation_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations", "{{conversation_id}}", "messages"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"type\": \"text\",\n  \"content\": \"This is a reply!\",\n  \"reply_to_id\": {{message_id}}\n}"
            }
          }
        },
        {
          "name": "Send image message (multipart)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('type is image', () => pm.expect(json.data.type).to.equal('image'));",
                  "pm.test('has file_url', () => pm.expect(json.data.file_url).to.be.a('string'));",
                  "pm.test('has file_metadata', () => pm.expect(json.data.file_metadata).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations/{{conversation_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations", "{{conversation_id}}", "messages"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "image", "type": "text" },
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Send file message (multipart)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations/{{conversation_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations", "{{conversation_id}}", "messages"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "file", "type": "text" },
                { "key": "file", "type": "file", "src": "" }
              ]
            }
          }
        },
        {
          "name": "Send text – empty content (expect 422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept",        "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/chat/conversations/{{conversation_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["chat", "conversations", "{{conversation_id}}", "messages"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"type\": \"text\",\n  \"content\": \"\"\n}"
            }
          }
        }
      ]
    },

