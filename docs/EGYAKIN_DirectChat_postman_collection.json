    {
      "name": "12 – File Download",
      "item": [
        {
          "name": "Download file via signed URL",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Paste the full file_url from any file message response into the request URL.",
                  "// The signed URL is self-authenticating — no Authorization header needed."
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 403', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 403]);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('has content-disposition', () => {",
                  "    pm.expect(pm.response.headers.get('Content-Disposition')).to.include('attachment');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "PASTE_FULL_FILE_URL_HERE",
              "host": ["PASTE_FULL_FILE_URL_HERE"]
            },
            "description": "Paste the complete file_url from a file/image/voice message response. No Authorization header needed — the URL is signed."
          }
        },
        {
          "name": "Download expired/tampered URL (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/chat/files/1?signature=invalid&expires=0&user_id=1",
              "host": ["{{base_url}}"],
              "path": ["chat", "files", "1"],
              "query": [
                { "key": "signature", "value": "invalid" },
                { "key": "expires",   "value": "0" },
                { "key": "user_id",   "value": "1" }
              ]
            }
          }
        }
      ]
    },

